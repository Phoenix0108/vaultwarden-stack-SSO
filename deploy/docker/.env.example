# Copier en .env (chmod 600, hors dépôt versionné) et renseigner les valeurs réelles.
# Générer des secrets forts, par ex. : openssl rand -base64 48

VW_ADMIN_TOKEN=CHANGE_ME_STRONG_RANDOM_TOKEN

# --- SSO OIDC (Authentik) — Phase 5 ---
# SSO_CLIENT_ID / SSO_CLIENT_SECRET : depuis le Provider OAuth2/OIDC créé côté Authentik pour Vaultwarden.
VW_SSO_CLIENT_ID=CHANGE_ME
VW_SSO_CLIENT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET
# VW_SSO_AUTHORITY : coller VERBATIM l'issuer depuis
#   https://auth.vaultwardensso.local/application/o/<slug>/.well-known/openid-configuration
# (casse exacte — piège déjà rencontré sur l'itération AD FS, cf. legacy/docs/00_RETROSPECTIVE_embuches.md #7)
VW_SSO_AUTHORITY=https://auth.vaultwardensso.local/application/o/CHANGE_ME_SLUG/
