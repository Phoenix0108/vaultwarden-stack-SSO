# =============================================================================
# 00_environment.env.example
# -----------------------------------------------------------------------------
# Config centrale de ce depot : TOUTES les valeurs specifiques a VOTRE
# infrastructure (realm AD, hostnames, IP du DC, reseaux clients...) vivent
# ICI et nulle part ailleurs. Aucun autre fichier de ce depot ne doit
# contenir de valeur en dur specifique a un site -- si vous en trouvez une,
# c'est un bug a signaler/corriger.
#
# Usage :
#   1. Copier ce fichier en `deploy/environment.env` (jamais versionne, deja
#      couvert par .gitignore via le motif *.env) et renseigner VOS valeurs.
#   2. Cote DC (PowerShell), avant d'executer un script de deploy/04_kerberos,
#      deploy/01_tls ou deploy/06_gpo :
#        . .\deploy\00_Set-Environment.ps1
#      (dot-source obligatoire -- un simple ".\00_Set-Environment.ps1" ne laisse
#      rien dans la session appelante). Tous les scripts PowerShell de ce
#      depot lisent alors leurs parametres par defaut depuis ces variables :
#      plus besoin de retaper le realm/l'IP du DC/etc. sur chaque commande.
#   3. Cote hote Docker (bash), les scripts de deploy/01_tls et deploy/05_authentik
#      sourcent automatiquement deploy/environment.env s'il est present --
#      rien a faire. Pour un usage manuel : `set -a; source deploy/environment.env; set +a`.
#
# Format : KEY=VALUE par ligne, un commentaire commence par '#', lignes vides
# ignorees. Pas de guillemets necessaires sauf valeur contenant des espaces.
# =============================================================================

# --- Active Directory -------------------------------------------------------
# Realm Kerberos, TOUJOURS en MAJUSCULES (ex: CONTOSO.LOCAL).
REALM=EXAMPLE.LOCAL
# Meme domaine, en minuscules -- c'est la zone DNS AD (ex: contoso.local).
DOMAIN_DNS=example.local
# Nom NetBIOS du domaine, tel qu'utilise par setspn/smbclient (ex: CONTOSO).
DOMAIN_NETBIOS=EXAMPLE
# IP du DC utilise comme KDC principal / cible LDAPS / autorite de certification.
# Plusieurs sites AD (KDC secondaires) : render-blueprint.sh ne genere qu'un
# seul "kdc = ..." -- ajouter les lignes supplementaires a la main dans
# kerberos-sso-blueprint.rendered.yaml avant import (une par KDC), cf. le
# commentaire au-dessus du bloc krb5_conf dans le template.
DC_IP=10.0.0.10

# --- Hostnames de la stack (SAN du certificat, vhosts Caddy) ---------------
VAULT_HOSTNAME=vault.example.local
AUTH_HOSTNAME=auth.example.local

# --- Reseaux clients autorises pour la redirection Kerberos automatique ----
# Liste de CIDR separes par des virgules. PLUSIEURS reseaux/VLAN sont
# supportes nativement (LAN filaire, WiFi corporate, VPN site-to-site, autre
# site AD...) -- il suffit de les enumerer ici, aucune limite au nombre.
# Un client dont l'IP n'est dans AUCUN de ces CIDR voit simplement le
# formulaire mot de passe classique (fallback), jamais une erreur bloquante.
# IMPORTANT : PAS d'espace apres la virgule (ce fichier est aussi `source`
# directement en bash par les scripts de deploy/ -- "a, b" y casse le parsing
# de l'assignation). Toujours "192.168.100.0/24,10.20.30.0/24", jamais
# "192.168.100.0/24, 10.20.30.0/24".
CLIENT_SUBNETS=192.168.100.0/24

# --- PKI interne (AD CS) -----------------------------------------------------
# Decouverte en UNE commande sur le DC : certutil -ADCA
#   dNSHostName = <machine>.<domaine>  (partie avant le 1er point) + cn = <nom-CA>
#   -> CA_CONFIG = "<machine>\<nom-CA>"  (ex: dNSHostName=SRVDC.example.local,
#      cn=example-SRVDC-CA -> CA_CONFIG=SRVDC\example-SRVDC-CA)
CA_CONFIG=SRVDC\ExampleCA
# Meme commande `certutil -ADCA` : la ligne "Cert Hash(sha1): xx xx xx ..."
# (espaces supprimes, majuscules) EST le thumbprint racine SI la ligne
# "Root Certificate: Subject matches Issuer" apparait juste au-dessus (CA
# Enterprise racine -- cas par defaut de ce depot). Sinon (CA subordonnee) :
# Get-ChildItem Cert:\LocalMachine\Root sur le DC, colonne Thumbprint de la
# VRAIE racine (celle dont le Subject correspond a votre chaine de confiance).
CA_ROOT_THUMBPRINT=CHANGE_ME_SHA1_THUMBPRINT
CERT_TEMPLATE=WebServer

# --- Organisation AD ---------------------------------------------------------
# Nom (PAS un DN) de l'OU peuplee des comptes a synchroniser par la Source
# LDAP Authentik -- CREEE AUTOMATIQUEMENT par Setup-LDAPBind-DC.ps1 si absente
# (a la racine du domaine) : n'importe quel nom convient, meme inedit.
LDAP_SYNC_OU_NAME=Vaultwarden
# DN COMPLET (pas juste un nom) de l'OU contenant les postes clients, cible de
# la GPO navigateurs -- DOIT DEJA EXISTER avec vos vrais postes dedans, ce
# depot ne la cree jamais. Decouverte sur le DC :
#   Get-ADOrganizationalUnit -Filter * | Select-Object Name, DistinguishedName
# copier tel quel le DistinguishedName de l'OU voulue. Exemple pour un domaine
# vaultwardensso.local avec une OU "Postes" a la racine :
#   GPO_TARGET_OU_DN=OU=Postes,DC=vaultwardensso,DC=local
# OU imbriquee (ex. sous un site "Paris") : OU=Postes,OU=Paris,DC=...,DC=...
GPO_TARGET_OU_DN=OU=Postes,DC=example,DC=local

# --- Comptes de service (noms seulement -- les mots de passe sont generes
#     par les scripts eux-memes, jamais stockes dans ce fichier) -----------
# Ces 3 valeurs sont des noms A CREER, pas a decouvrir : les valeurs par
# defaut conviennent telles quelles tant qu'elles n'entrent pas en collision
# avec un compte/groupe existant (Setup-KerberosSPNEGO-DC.ps1 et
# Setup-LDAPBind-DC.ps1 refusent de continuer si le compte existe deja --
# renommer ici si besoin, pas de contrainte de format particuliere).
KERBEROS_SVC_ACCOUNT=svc-authentik-krb
LDAP_BIND_ACCOUNT=svc-authentik-ldap
DENY_INTERACTIVE_GROUP=GG-SvcAccounts-DenyInteractiveLogon

# --- Identifiant magique OIDCWarden (NE PAS MODIFIER) -----------------------
# Constante imposee par le code d'OIDCWarden (route get_dummy_master_password_
# policy, cf. src/api/core/organizations.rs) -- ce n'est pas "votre" valeur,
# c'est un identifiant fixe attendu tel quel par le fork. Documente ici pour
# que le signet SSO genere par Deploy-KerberosSSO-GPO.ps1 reste coherent avec
# le reste de la stack sans que ce script ait a le deviner.
SSO_ORG_ENROLLMENT_IDENTIFIER=00000000-01DC-01DC-01DC-000000000000
